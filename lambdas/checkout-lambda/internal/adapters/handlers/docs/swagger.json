{
    "swagger": "2.0",
    "info": {
        "description": "Ticketera Cloud Checkout Microservice API",
        "title": "Checkout API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:3004",
    "basePath": "/",
    "paths": {
        "/checkout": {
            "post": {
                "description": "Validates payload and triggers async queue for payment",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "checkout"
                ],
                "summary": "Process a checkout",
                "parameters": [
                    {
                        "description": "Checkout Request object",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.CheckoutRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "$ref": "#/definitions/domain.CheckoutResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.CheckoutRequest": {
            "type": "object",
            "properties": {
                "event_id": {
                    "type": "string"
                },
                "method": {
                    "type": "string"
                },
                "seats": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "domain.CheckoutResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "order_id": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        }
    }
}